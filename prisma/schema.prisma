// prisma/schema.prisma — Phase 2 complete schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════

enum Role {
  SUPER_ADMIN
  ADMIN
  BUSINESS_OWNER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

enum MediaType {
  IMAGE // kept for backward compatibility — do not use in new code
  VIDEO
  COVER // ← NEW Phase 5
  LOGO // ← NEW Phase 5
  PHOTO // ← NEW Phase 5
}

enum MediaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FlagStatus {
  PENDING
  RESOLVED
  IGNORED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  WHATSAPP
  YOUTUBE
  TIKTOK
  TELEGRAM
  WEBSITE
  OTHER
}

enum AuditAction {
  // ── Phase 1 values — kept for backward compatibility ──────
  // src/features/auth/actions.ts references these by name.
  // Do NOT remove or rename them without updating that file.
  USER_CREATED
  USER_DELETED
  EMAIL_VERIFIED
  PASSWORD_RESET

  // ── Phase 2 additions ─────────────────────────────────────
  USER_ROLE_CHANGED
  USER_BANNED
  USER_RESTORED
  LISTING_CREATED
  LISTING_UPDATED
  LISTING_SUBMITTED
  LISTING_SUSPENDED
  LISTING_RESTORED
  LISTING_DELETED
  VERIFICATION_GRANTED
  VERIFICATION_REVOKED
  MEDIA_UPLOADED
  MEDIA_APPROVED
  MEDIA_REJECTED
  MEDIA_DELETED
  MEDIA_REORDERED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  CATEGORY_REORDERED
  SETTING_UPDATED
  FLAG_SUBMITTED
  FLAG_RESOLVED
  FLAG_IGNORED
}

enum NotificationType {
  LISTING_PUBLISHED
  LISTING_SUSPENDED
  LISTING_RESTORED
  EMAIL_VERIFIED
  VERIFICATION_GRANTED
  VERIFICATION_REVOKED
  VIDEO_APPROVED
  VIDEO_PENDING_REVIEW // ← NEW Phase 5
  VIDEO_REJECTED
  FLAG_SUBMITTED
}

// ═══════════════════════════════════════════════════════════
// AUTH MODELS  ← Phase 1 — names/structure must not change
// without a coordinated migration + code update.
// ═══════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  role          Role      @default(BUSINESS_OWNER)
  image         String?
  bannedAt     DateTime?
  bannedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // ── Auth relations (Phase 1) ─────────────────────────────
  accounts                Account[]
  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  // ── Domain relations (Phase 2) ───────────────────────────
  ownedListings    BusinessProfile[] @relation("ListingOwner")
  verifiedListings BusinessProfile[] @relation("ListingVerifier")
  deletedListings  BusinessProfile[] @relation("ListingDeleter")
  uploadedMedia    MediaFile[]       @relation("MediaUploader")
  notifications    Notification[]
  reportedFlags    ReviewFlag[]      @relation("FlagReporter")
  resolvedFlags    ReviewFlag[]      @relation("FlagResolver")
  updatedSettings  PlatformSetting[] @relation("SettingUpdater")

  // Named relation — kept from Phase 1 to avoid breaking auth code
  auditLogs     AuditLog[]  @relation("ActorAuditLogs")
  reviewedMedia MediaFile[] @relation("MediaReviewer")

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

// Required by @auth/prisma-adapter — do not rename
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// Required by @auth/prisma-adapter — do not remove
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ═══════════════════════════════════════════════════════════
// GEOGRAPHY
// ═══════════════════════════════════════════════════════════

model Country {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  code      String   @unique
  createdAt DateTime @default(now())

  regions Region[]

  @@map("countries")
}

model Region {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  countryId String
  createdAt DateTime @default(now())

  country Country @relation(fields: [countryId], references: [id])
  cities  City[]

  @@index([countryId])
  @@map("regions")
}

model City {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  slug      String   @unique
  regionId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  region   Region            @relation(fields: [regionId], references: [id])
  listings BusinessProfile[]

  @@index([regionId])
  @@index([slug])
  @@map("cities")
}

// ═══════════════════════════════════════════════════════════
// TAXONOMY
// ═══════════════════════════════════════════════════════════

model Category {
  id            String   @id @default(cuid())
  nameAr        String
  nameEn        String
  slug          String   @unique
  descriptionAr String?
  descriptionEn String?
  icon          String?
  isVisible     Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subcategories Subcategory[]
  listings      BusinessProfile[]

  @@index([slug])
  @@index([isVisible, displayOrder])
  @@map("categories")
}

model Subcategory {
  id            String   @id @default(cuid())
  nameAr        String
  nameEn        String
  slug          String   @unique
  categoryId    String
  descriptionAr String? // ← ADD
  descriptionEn String? // ← ADD
  icon          String? // ← ADD
  isVisible     Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category Category          @relation(fields: [categoryId], references: [id])
  listings BusinessProfile[]

  @@index([categoryId])
  @@index([isVisible, displayOrder]) // ← ADD this index too
  @@map("subcategories")
}

// ═══════════════════════════════════════════════════════════
// BUSINESS PROFILE
// ═══════════════════════════════════════════════════════════

model BusinessProfile {
  id            String        @id @default(cuid())
  nameAr        String
  nameEn        String?
  slug          String        @unique
  descriptionAr String?       @db.Text
  descriptionEn String?       @db.Text
  status        ListingStatus @default(DRAFT)

  isVerified   Boolean   @default(false)
  verifiedById String?
  verifiedAt   DateTime?

  ownerId String

  cityId    String
  addressAr String?
  addressEn String?
  latitude  Float?
  longitude Float?

  categoryId    String
  subcategoryId String?

  coverImageUrl String?
  coverImageId  String? // ← NEW Phase 5: plain string ref to MediaFile.id
  logoImageUrl  String?
  logoImageId   String? // ← NEW Phase 5: plain string ref to MediaFile.id

  searchableText String? @db.Text

  viewCount   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  owner         User         @relation("ListingOwner", fields: [ownerId], references: [id])
  verifiedBy    User?        @relation("ListingVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  deletedByUser User?        @relation("ListingDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  city          City         @relation(fields: [cityId], references: [id])
  category      Category     @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  phoneNumbers PhoneNumber[]
  workingHours WorkingHours[]
  socialLinks  SocialLink[]
  mediaFiles   MediaFile[]
  flags        ReviewFlag[]

  @@index([status])
  @@index([ownerId])
  @@index([cityId])
  @@index([categoryId])
  @@index([slug])
  @@index([deletedAt])
  @@index([publishedAt])
  @@index([status, deletedAt])
  @@map("business_profiles")
}

model PhoneNumber {
  id         String   @id @default(cuid())
  businessId String
  number     String
  label      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("phone_numbers")
}

model WorkingHours {
  id         String    @id @default(cuid())
  businessId String
  dayOfWeek  DayOfWeek
  openTime   String?
  closeTime  String?
  isClosed   Boolean   @default(false)

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@index([businessId])
  @@map("working_hours")
}

model SocialLink {
  id         String         @id @default(cuid())
  businessId String
  platform   SocialPlatform
  url        String
  createdAt  DateTime       @default(now())

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("social_links")
}

model MediaFile {
  id                 String      @id @default(cuid())
  businessId         String
  type               MediaType
  cloudinaryPublicId String?     @unique // ← NOW nullable (Phase 5 migration)
  url                String? // ← NOW nullable (Phase 5 migration)
  thumbnailUrl       String?
  mimeType           String? // ← NEW Phase 5
  status             MediaStatus @default(PENDING)
  displayOrder       Int         @default(0)
  width              Int?
  height             Int?
  durationSeconds    Int?
  sizeBytes          Int?
  rejectionReason    String?
  reviewedById       String? // ← NEW Phase 5
  reviewedAt         DateTime? // ← NEW Phase 5
  uploadedById       String
  approvedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  uploadedBy User            @relation("MediaUploader", fields: [uploadedById], references: [id])
  reviewedBy User?           @relation("MediaReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([status])
  @@index([type, status])
  @@map("media_files")
}

// ═══════════════════════════════════════════════════════════
// MODERATION
// ═══════════════════════════════════════════════════════════

model ReviewFlag {
  id              String     @id @default(cuid())
  businessId      String
  reportedById    String?
  reason          String
  details         String?    @db.Text
  status          FlagStatus @default(PENDING)
  resolvedById    String?
  resolvedAt      DateTime?
  resolutionNotes String?
  createdAt       DateTime   @default(now())

  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reportedBy User?           @relation("FlagReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  resolvedBy User?           @relation("FlagResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([status])
  @@map("review_flags")
}

// ═══════════════════════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════════════════════

model AuditLog {
  id             String      @id @default(cuid())
  actorId        String?
  actorEmail     String?
  actorRole      Role?
  action         AuditAction
  entityType     String
  entityId       String
  previousValues Json?
  newValues      Json?
  ipAddress      String?
  createdAt      DateTime    @default(now())

  // Named relation kept from Phase 1 — matches User.auditLogs above
  actor User? @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  data      Json?
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════
// PLATFORM SETTINGS
// ═══════════════════════════════════════════════════════════

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedById String?
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation("SettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([key])
  @@map("platform_settings")
}
